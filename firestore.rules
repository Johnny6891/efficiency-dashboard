rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 前端只需要讀取 efficiency_stats
    match /efficiency_stats/{document} {
      allow read: if true;
      allow write: if false;
    }

    // orders 集合：僅供 GAS 寫入（透過 Service Account 繞過規則）
    match /orders/{document} {
      allow read: if false;
      allow write: if false;
    }
  }
}
